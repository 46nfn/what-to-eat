{
  "name": "what-to-eat-desktop",
  "version": "2.0.0",
  "description": "这顿吃什么 - 桌面客户端",
  "main": "main.js",
  "author": "这顿吃什么团队",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.whattoeat.desktop",
    "productName": "这顿吃什么",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "../dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "../public/icons/icon-512x512.png",
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "这顿吃什么",
      "installerIcon": "../public/icons/icon-512x512.png",
      "uninstallerIcon": "../public/icons/icon-512x512.png",
      "installerHeaderIcon": "../public/icons/icon-512x512.png",
      "license": "../LICENSE.txt",
      "installerLanguages": ["zh_CN", "en_US"]
    },
    "mac": {
      "target": ["dmg"],
      "icon": "../public/icons/icon-512x512.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "../public/icons/icon-512x512.png"
    }
  }
}
